generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  category    String
  material    String
  sku         String   @unique
  images      Json
  badge       String?
  isFeatured  Boolean  @default(false)
  // `category` is the PRIMARY category (kept for display/back-compat); a product
  // can belong to MANY categories via `categories` (slugs), which drives filtering.
  categories  String[] @default([])
  occasions   String[] @default([])
  tags        String[] @default([])
  styles      String[] @default([])
  stock       Int      @default(10)
  compareAtPrice Int?
  // Owner-controlled position on the shop front page (1 = first).
  // Null = not pinned; pinned products always come before unpinned.
  displayOrder Int?
  createdAt   DateTime @default(now())

  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]

  @@index([category])
  @@index([material])
  @@index([isFeatured])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     Int      @unique @default(autoincrement())
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress Json
  notes           String?
  totalAmount     Float
  discountAmount  Float    @default(0)
  couponCode      String?
  paymentStatus   String   @default("pending")
  paymentMethod   String   @default("online")
  paymentId       String?
  orderStatus     String   @default("processing")
  createdAt       DateTime @default(now())

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([orderStatus])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String?
  variantId       String?
  quantity        Int
  priceAtPurchase Float

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Category {
  id    String  @id @default(cuid())
  name  String
  slug  String  @unique
  image String?
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  phone        String?
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  addresses     Address[]
  wishlistItems WishlistItem[]
  orders        Order[]
  reviews       Review[]
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String?
  line1     String
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WishlistItem {
  id        String @id @default(cuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String
  discountValue  Float
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// Owner-managed home hero. Multiple active slides rotate as a crossfade
// slideshow. focal* = CSS object-position so the owner can "crop" which part
// of the image shows on each device when it's cover-cropped.
model HeroSlide {
  id             String   @id @default(cuid())
  imageUrl       String
  mobileImageUrl String?  // optional separate image for phones
  focalDesktop   String   @default("50% 50%")
  focalMobile    String   @default("50% 50%")
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([isActive, order])
}

// Generic key/value store for owner-editable site config:
//   hero.durationMs  -> number   (ms each hero slide stays before changing)
//   ribbon.messages  -> string[] (rotating announcement-bar messages)
model Setting {
  key   String @id
  value Json
}

model Review {
  id          String   @id @default(cuid())
  productId   String
  userId      String?
  authorName  String
  rating      Int      // 1–5
  body        String?
  images      Json     @default("[]")
  isVerified  Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
}
