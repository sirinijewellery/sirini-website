generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  category    String
  material    String
  sku         String   @unique
  images      Json
  badge       String?
  isFeatured  Boolean  @default(false)
  // Optional per-product SEO overrides (fall back to auto-generated when null).
  metaTitle       String?
  metaDescription String?
  // `category` is the PRIMARY category (kept for display/back-compat); a product
  // can belong to MANY categories via `categories` (slugs), which drives filtering.
  categories  String[] @default([])
  occasions   String[] @default([])
  tags        String[] @default([])
  styles      String[] @default([])
  stock       Int      @default(10)
  compareAtPrice Int?
  // Owner-controlled position on the shop front page (1 = first).
  // Null = not pinned; pinned products always come before unpinned.
  displayOrder Int?
  createdAt   DateTime @default(now())

  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  terms         ProductTerm[]

  @@index([category])
  @@index([material])
  @@index([isFeatured])
}

// ── Admin-managed taxonomy (dynamic, multi-dimension) ──────────────────────
// A TaxonomyGroup is a "Shop by ___" dimension (Category, Look, Collection,
// Stone, Colour, Occasion, or any new one the owner creates). Terms are the
// options within it; only the Category group is hierarchical (main -> sub).
// Products link to terms via ProductTerm (many-to-many).
model TaxonomyGroup {
  id           String         @id @default(cuid())
  slug         String         @unique
  label        String
  hierarchical Boolean        @default(false)
  sortOrder    Int            @default(0)
  showInMenu   Boolean        @default(true)
  isSystem     Boolean        @default(false)
  terms        TaxonomyTerm[]
}

model TaxonomyTerm {
  id         String         @id @default(cuid())
  groupId    String
  group      TaxonomyGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     TaxonomyTerm?  @relation("TermChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children   TaxonomyTerm[] @relation("TermChildren")
  slug       String
  label      String
  blurb      String?
  coverImage String?
  coverFocal String?        @default("center")
  hexColor   String?
  sortOrder  Int            @default(0)
  showInMenu Boolean        @default(true)
  products   ProductTerm[]

  @@unique([groupId, slug])
  @@index([groupId])
  @@index([parentId])
}

model ProductTerm {
  productId String
  termId    String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  term      TaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@id([productId, termId])
  @@index([termId])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     Int      @unique @default(autoincrement())
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress Json
  notes           String?
  totalAmount     Float
  discountAmount  Float    @default(0)
  couponCode      String?
  paymentStatus   String   @default("pending")
  paymentMethod   String   @default("online")
  // Unique so the same Razorpay payment can never create two orders — the
  // verify route's idempotency guard is also enforced at the DB level.
  paymentId       String?  @unique
  orderStatus     String   @default("processing")
  createdAt       DateTime @default(now())

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([orderStatus])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String?
  variantId       String?
  quantity        Int
  priceAtPurchase Float

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Category {
  id         String  @id @default(cuid())
  name       String
  slug       String  @unique
  image      String?
  // Owner-controlled homepage placement: lower sortOrder shows first;
  // showOnHome toggles whether the category card appears on the homepage grid.
  sortOrder  Int     @default(0)
  showOnHome Boolean @default(true)
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  // Optional login handle (admins sign in with this, customers use email).
  // Stored lowercased; matched case-insensitively.
  username     String?  @unique
  name         String?
  phone        String?
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  addresses     Address[]
  wishlistItems WishlistItem[]
  orders        Order[]
  reviews       Review[]
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String?
  line1     String
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WishlistItem {
  id        String @id @default(cuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String
  discountValue  Float
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// Customer contact-form submissions. ALWAYS persisted (source of truth — the
// owner reads them at /admin/messages); the notification email is best-effort
// on top, so no message is ever lost while email is unconfigured or down.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

// Owner-managed home hero. Multiple active slides rotate as a crossfade
// slideshow. focal* = CSS object-position so the owner can "crop" which part
// of the image shows on each device when it's cover-cropped.
model HeroSlide {
  id             String   @id @default(cuid())
  imageUrl       String
  mobileImageUrl String?  // optional separate image for phones
  focalDesktop   String   @default("50% 50%")
  focalMobile    String   @default("50% 50%")
  brightness     Float    @default(1.0)
  contrast       Float    @default(1.0)
  overlayOpacity Float    @default(0.4)
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([isActive, order])
}

// Generic key/value store for owner-editable site config:
//   hero.durationMs  -> number   (ms each hero slide stays before changing)
//   ribbon.messages  -> string[] (rotating announcement-bar messages)
model Setting {
  key   String @id
  value Json
}

// Owner-managed blog / styling-guide articles. Mirrors the legacy `Article`
// shape in lib/blog.ts so existing renderers work unchanged. `body` is a JSON
// array of { heading?, paragraphs[] }; `relatedLinks` a JSON array of {label,href}.
model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String
  coverImage      String
  body            Json      @default("[]")
  relatedLinks    Json      @default("[]")
  readMins        Int       @default(5)
  isPublished     Boolean   @default(true)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, publishedAt])
}

model Review {
  id          String   @id @default(cuid())
  productId   String
  userId      String?
  authorName  String
  rating      Int      // 1–5
  body        String?
  images      Json     @default("[]")
  isVerified  Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
}
